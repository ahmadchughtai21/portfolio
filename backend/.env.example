# ─── App ──────────────────────────────────────────────────────
APP_NAME=portfolio-api
DEBUG=false

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. The Vite dev server
# is the only consumer for now.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── RAG provider ─────────────────────────────────────────────
# "mock"   → keyword-based matcher, no external deps, ships now
# "gemini" → Google Gemini generation (requires requirements-rag.txt
#            and a valid GEMINI_API_KEY)
RAG_PROVIDER=gemini

# ─── Gemini (read only when RAG_PROVIDER=gemini) ──────────────
# Get a free API key at https://aistudio.google.com/apikey
# (Google AI Studio → "Create API key" — no billing required for
# the free tier).
GEMINI_API_KEY=PASTE_YOUR_KEY_HERE

# Free-tier model. Override if you have access to a paid tier.
#   gemini-1.5-flash      ← default, stable, 15 RPM, 1500 RPD
#   gemini-1.5-flash-8b   ← smaller/faster, same limits
#   gemini-2.0-flash      ← newer, same free-tier limits
GEMINI_MODEL=gemini-1.5-flash

# How many top-scoring knowledge entries to inject as RAG context.
RAG_TOP_K=3

# Generation params (kept conservative to stay inside the free tier).
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_OUTPUT_TOKENS=400
